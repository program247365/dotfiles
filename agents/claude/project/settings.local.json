{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "WebFetch(domain:www.lazyvim.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebSearch",
      "WebFetch(domain:bear.app)",
      "Read(//Users/kevin/.claude/**)",
      "WebFetch(domain:www.anthropic.com)",
      "Bash(python3:*)",
      "Skill(bear-notes)",
      "Skill(plan-exit-review)",
      "Skill(workday)",
      "Skill(visual-explainer)",
      "WebFetch(domain:docs.anthropic.com)",
      "mcp__plugin_playwright_playwright__browser_run_code",
      "Bash(qmd query:*)",
      "Bash(qmd search:*)",
      "Bash(bcli search:*)",
      "Bash(bcli get:*)",
      "Bash(bcli create:*)",
      "Bash(bcli edit:*)",
      "Bash(bcli sync:*)",
      "Bash(qmd collection:*)",
      "Bash(cat:*)",
      "Bash(qmd status:*)",
      "Bash(qmd:*)",
      "mcp__plugin_playwright_playwright__browser_close",
      "Bash(bcli ls:*)",
      "Bash(bcli tags:*)",
      "Bash(bcli --help)",
      "WebFetch(domain:randsinrepose.com)",
      "Skill(update-config)",
      "WebFetch(domain:docs.warp.dev)",
      "Bash(~/.local/bin/bcli get:*)",
      "WebFetch(domain:www.msgvault.io)",
      "WebFetch(domain:x.com)",
      "WebFetch(domain:nitter.net)",
      "WebFetch(domain:xcancel.com)",
      "WebFetch(domain:vxtwitter.com)",
      "WebFetch(domain:fixupx.com)",
      "WebFetch(domain:www.npmjs.com)",
      "Bash(mise ls:*)",
      "Bash(xargs ls:*)",
      "Bash(dev-browser:*)",
      "WebFetch(domain:issues.chromium.org)",
      "WebFetch(domain:developer.chrome.com)",
      "WebFetch(domain:lazyagent.dev)",
      "Bash(nvim --version)",
      "Bash(brew list:*)",
      "mcp__linear__list_projects",
      "mcp__linear__list_issue_labels"
    ],
    "deny": [],
    "ask": []
  },
  "disabledMcpjsonServers": [
    "figma"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/agents/claude/hooks/guard-destructive.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude finished\" with title \"Claude Code\" sound name \"Ping\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  }
}
