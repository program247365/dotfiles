#!/usr/bin/env bash
# kit — Kevin's installed tools
# Fast fuzzy recall of everything declared in dotfiles
#
# Usage:
#   kit              interactive fuzzy search
#   kit <query>      search pre-filtered to <query>
#   kit index        rebuild ~/.kit/index.json
#   kit recent [n]   show n recently added tools (default: 10)
#   kit missing      show tools declared in dotfiles but not installed

set -euo pipefail

DOTFILES="${DOTFILES:-$HOME/.dotfiles}"
KIT_HOME="$HOME/.kit"
INDEX="$KIT_HOME/index.json"  # used by cmd_index, cmd_search, cmd_recent, cmd_missing

main() {
  case "${1:-}" in
    index)    shift; cmd_index "$@" ;;
    recent)   shift; cmd_recent "$@" ;;
    missing)  shift; cmd_missing "$@" ;;
    add)      shift; cmd_add "$@" ;;
    -h|--help)
      echo "kit — Kevin's installed tools"
      echo ""
      echo "Usage:"
      echo "  kit              interactive fuzzy search"
      echo "  kit <query>      search pre-filtered to <query>"
      echo "  kit index        rebuild ~/.kit/index.json"
      echo "  kit recent [n]   show n recently added tools (default: 10)"
      echo "  kit missing      show tools declared in dotfiles but not installed"
      echo "  kit add <name>   add formula to Brewfile, install, and reindex"
      echo ""
      echo "Picker keys:"
      echo "  Enter            run selected tool"
      echo "  ctrl-h           show --help for selected tool"
      ;;
    *)        cmd_search "${1:-}" ;;
  esac
}

# ── helpers ──────────────────────────────────────────────────────────────────

_require() {
  for cmd in "$@"; do
    command -v "$cmd" >/dev/null 2>&1 || { echo "kit: required command not found: $cmd" >&2; exit 1; }
  done
}

_extract_desc() {
  # Extract description from an inline comment on a line.
  # "# https://foo.com - Real desc" → "Real desc"
  # "# https://foo.com"             → "foo.com"  (URL-only: use bare domain as fallback)
  local line="$1"
  local desc="" url=""
  if [[ "$line" == *" #"* ]]; then
    desc="${line#* #}"
    desc="${desc## }"
    # Capture leading URL before stripping (used as fallback if nothing else remains)
    if [[ "$desc" =~ ^https?://([^ ]*) ]]; then
      url="${BASH_REMATCH[1]}"
    fi
    # Strip leading URL and optional separator; use -E (BSD sed doesn't support \? in BRE)
    desc=$(printf '%s' "$desc" | sed -E 's|^https?://[^ ]* *[-–]* *||')
    # Strip trailing URLs
    desc=$(printf '%s' "$desc" | sed -E 's| https?://[^ ]*||g')
    # Trim whitespace
    desc=$(printf '%s' "$desc" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    # Fall back to bare URL domain if comment was URL-only
    [[ -z "$desc" && -n "$url" ]] && desc="$url"
  fi
  printf '%s' "$desc"
}

_get_dotfiles_added() {
  # Find the first commit that introduced 'name' (quoted) into Brewfile.
  local name="$1"
  git -C "$DOTFILES" log --format="%ad" --date=format:"%Y-%m-%d" -S "'${name}'" -- Brewfile 2>/dev/null | tail -1
}

_stale_warn() {
  [[ ! -f "$INDEX" ]] && return
  local idx_mtime
  idx_mtime=$(stat -f %m "$INDEX" 2>/dev/null || stat -c %Y "$INDEX" 2>/dev/null)

  local sources=(
    "$DOTFILES/Brewfile"
    "$DOTFILES/zsh/aliases.zsh"
    "$DOTFILES/functions/functions.zsh"
    "$DOTFILES/agents/shell.zsh"
    "$DOTFILES/docker/aliases.zsh"
    "$DOTFILES/git/aliases.zsh"
    "$DOTFILES/xcode/aliases.zsh"
  )

  for f in "${sources[@]}"; do
    [[ -f "$f" ]] || continue
    local f_mtime
    f_mtime=$(stat -f %m "$f" 2>/dev/null || stat -c %Y "$f" 2>/dev/null)
    if (( f_mtime > idx_mtime )); then
      echo "⚠ index may be stale ($(basename "$f") changed) — run 'kit index' to refresh" >&2
      return
    fi
  done
}

# ── cmd_index ─────────────────────────────────────────────────────────────────

cmd_index() {
  _require jq git brew

  echo "Building kit index..." >&2
  mkdir -p "$KIT_HOME"

  # Load existing index to preserve manual help_flag overrides
  local existing_index="[]"
  [[ -f "$INDEX" ]] && existing_index=$(cat "$INDEX")

  # Temp file: accumulate newline-delimited JSON objects, combine at end
  local tmp
  tmp=$(mktemp)
  # shellcheck disable=SC2064
  trap "rm -f $tmp" EXIT

  # ── Brewfile ────────────────────────────────────────────────────────────────
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ "$line" =~ ^(tap|cask_args)[[:space:]] ]] && continue

    local type="" full_name="" name="" desc=""

    if [[ "$line" =~ ^brew\ \'([^\']+)\' ]]; then
      full_name="${BASH_REMATCH[1]}"
      name="${full_name##*/}"   # strip tap prefix: 'keith/formulae/reminders-cli' → 'reminders-cli'
      type="brew"
    elif [[ "$line" =~ ^cask\ \'([^\']+)\' ]]; then
      full_name="${BASH_REMATCH[1]}"
      name="$full_name"
      type="cask"
    else
      continue
    fi

    desc=$(_extract_desc "$line")

    # Preserve existing help_flag override; default to --help
    local help_flag="--help"
    local existing_flag
    existing_flag=$(printf '%s' "$existing_index" | jq -r --arg n "$name" \
      '.[] | select(.name == $n) | .help_flag // ""' 2>/dev/null || true)
    [[ -n "$existing_flag" ]] && help_flag="$existing_flag"

    # dotfiles_added: first git commit that introduced this name to Brewfile
    local dotfiles_added
    dotfiles_added=$(_get_dotfiles_added "$name")

    jq -n \
      --arg  name           "$name" \
      --arg  type           "$type" \
      --arg  desc           "$desc" \
      --arg  dotfiles_added "$dotfiles_added" \
      --arg  help_flag      "$help_flag" \
      '{name:$name,type:$type,description:$desc,dotfiles_added:$dotfiles_added,
        installed:false,installed_at:null,help_flag:$help_flag}' \
      >> "$tmp"

  done < "$DOTFILES/Brewfile"

  # ── bin/ scripts ────────────────────────────────────────────────────────────
  for f in "$DOTFILES/bin/"*; do
    [[ -f "$f" ]] || continue
    local name type desc dotfiles_added help_flag existing_flag
    name=$(basename "$f")
    type="bin"
    # First non-shebang comment line as description
    desc=$(grep -m1 '^#[^!]' "$f" 2>/dev/null | sed 's/^#[[:space:]]*//' || true)
    desc="${desc:-shell script}"
    dotfiles_added=$(git -C "$DOTFILES" log --format="%ad" --date=format:"%Y-%m-%d" \
      -- "bin/$name" 2>/dev/null | tail -1 || true)
    help_flag="--help"
    existing_flag=$(printf '%s' "$existing_index" | jq -r --arg n "$name" \
      '.[] | select(.name == $n) | .help_flag // ""' 2>/dev/null || true)
    [[ -n "$existing_flag" ]] && help_flag="$existing_flag"

    jq -n \
      --arg name           "$name" \
      --arg type           "$type" \
      --arg desc           "$desc" \
      --arg dotfiles_added "$dotfiles_added" \
      --arg help_flag      "$help_flag" \
      '{name:$name,type:$type,description:$desc,dotfiles_added:$dotfiles_added,
        installed:true,installed_at:null,help_flag:$help_flag}' \
      >> "$tmp"
  done

  # ── aliases and functions from .zsh files ────────────────────────────────────
  # Scan all known .zsh source files for alias and function definitions
  local zsh_sources=(
    "$DOTFILES/zsh/aliases.zsh"
    "$DOTFILES/docker/aliases.zsh"
    "$DOTFILES/git/aliases.zsh"
    "$DOTFILES/xcode/aliases.zsh"
    "$DOTFILES/agents/shell.zsh"
    "$DOTFILES/functions/functions.zsh"
  )

  for zf in "${zsh_sources[@]}"; do
    [[ -f "$zf" ]] || continue
    local prev_comment=""

    while IFS= read -r line; do
      # Track comment lines for function descriptions
      if [[ "$line" =~ ^[[:space:]]*#[[:space:]]?(.*) ]]; then
        prev_comment="${BASH_REMATCH[1]}"
        continue
      fi

      # alias name='...' or alias name="..."
      if [[ "$line" =~ ^alias[[:space:]]+([A-Za-z0-9_!-]+)=[\'\"]([^\'\"]+)[\'\"] ]]; then
        local aname="${BASH_REMATCH[1]}"
        local acmd="${BASH_REMATCH[2]}"
        local adesc
        adesc=$(_extract_desc "$line")
        [[ -z "$adesc" ]] && adesc="alias for: $acmd"

        jq -n \
          --arg name "$aname" \
          --arg desc "$adesc" \
          '{name:$name,type:"alias",description:$desc,dotfiles_added:"",
            installed:true,installed_at:null,help_flag:"--help"}' \
          >> "$tmp"
        prev_comment=""
        continue
      fi

      # function_name() { — shell function definition
      if [[ "$line" =~ ^([a-zA-Z_][a-zA-Z0-9_-]*)\(\)[[:space:]]*\{ ]]; then
        local fname="${BASH_REMATCH[1]}"
        local fdesc="${prev_comment:-shell function}"

        jq -n \
          --arg name "$fname" \
          --arg desc "$fdesc" \
          '{name:$name,type:"function",description:$desc,dotfiles_added:"",
            installed:true,installed_at:null,help_flag:"--help"}' \
          >> "$tmp"
        prev_comment=""
        continue
      fi

      # Reset comment tracking on non-comment, non-definition lines
      prev_comment=""

    done < "$zf"
  done

  # ── brew cross-reference ─────────────────────────────────────────────────────
  echo "Cross-referencing with brew..." >&2

  local brew_formulae brew_casks
  brew_formulae=$(brew list --formula 2>/dev/null || true)
  brew_casks=$(brew list --cask 2>/dev/null || true)

  local brew_info_file
  brew_info_file=$(mktemp)
  brew info --json=v2 --installed 2>/dev/null > "$brew_info_file" \
    || echo '{"formulae":[],"casks":[]}' > "$brew_info_file"

  local tmp2
  tmp2=$(mktemp)

  jq -s '.' "$tmp" | jq \
    --arg formulae "$brew_formulae" \
    --arg casks    "$brew_casks" \
    --slurpfile info "$brew_info_file" \
    '
    def installed_formulae: ($formulae | split("\n") | map(select(length > 0)));
    def installed_casks:    ($casks    | split("\n") | map(select(length > 0)));

    map(
      . as $entry |
      if $entry.type == "brew" then
        if ($entry.name as $n | installed_formulae | any(. == $n)) then
          $entry |
          .installed = true |
          .installed_at = (
            ($info[0].formulae[] | select(.name == $entry.name) |
             .installed[0].installed_on // null |
             if . then (. | split("T")[0]) else null end) // null
          ) |
          # Fall back to brew formula desc when dotfiles comment is empty
          .description = (if .description == "" then
            (($info[0].formulae[] | select(.name == $entry.name) | .desc) // "")
          else .description end)
        else $entry end
      elif $entry.type == "cask" then
        if ($entry.name as $n | installed_casks | any(. == $n)) then
          $entry | .installed = true
        else $entry end
      else $entry end
    )
    ' > "$tmp2"

  rm -f "$brew_info_file"

  mv "$tmp2" "$INDEX"

  # Fetch help text for installed tools (parallel, 2s timeout each)
  echo "Fetching help text for installed tools..." >&2
  local help_tmp_dir
  help_tmp_dir=$(mktemp -d)

  while IFS=$'\t' read -r name installed help_flag; do
    [[ "$installed" != "true" ]] && continue
    command -v "$name" >/dev/null 2>&1 || continue
    (
      timeout 2 bash -c "$name $help_flag 2>&1 | head -80" \
        > "$help_tmp_dir/$name" 2>/dev/null || true
    ) &
  done < <(jq -r '.[] | [.name, (.installed | tostring), (.help_flag // "--help")] | @tsv' "$INDEX")

  wait

  local tmp3
  tmp3=$(mktemp)
  while IFS= read -r entry; do
    local name help_text
    name=$(printf '%s' "$entry" | jq -r '.name')
    help_text=""
    [[ -f "$help_tmp_dir/$name" ]] && help_text=$(cat "$help_tmp_dir/$name")
    printf '%s' "$entry" | jq --arg ht "$help_text" '. + {help_text: $ht}' >> "$tmp3"
  done < <(jq -c '.[]' "$INDEX")
  jq -s '.' "$tmp3" > "$INDEX"
  rm -f "$tmp3"
  rm -rf "$help_tmp_dir"

  local count
  count=$(jq 'length' "$INDEX")
  echo "Indexed $count entries → $INDEX" >&2
}

cmd_search() {
  local query="${1:-}"
  _require sk jq

  if [[ ! -f "$INDEX" ]]; then
    echo "No index found. Building..." >&2
    cmd_index
  fi

  _stale_warn

  # Format: name  [type]  description  [not installed]?
  # Help text is appended as a hidden tab-delimited field so sk searches it
  # without displaying it (--with-nth 1 shows only the display column).
  local sk_out sk_exit=0
  sk_out=$(
    paste \
      <(jq -r '.[] | [
          .name,
          ("[" + .type + "]"),
          .description,
          (if .installed then "" else "[not installed]" end)
        ] | @tsv' "$INDEX" | column -t -s $'\t') \
      <(jq -r '.[] | (.help_text // "") | gsub("\n"; " ") | gsub("\t"; " ")' "$INDEX") \
    | sk --query "$query" --ansi \
         --print-query \
         --delimiter $'\t' \
         --with-nth 1 \
         --preview 'cmd=$(echo {} | awk "{print \$1}"); ($cmd --help 2>&1 | head -50) || echo "(no --help)"' \
         --preview-window 'right:50%:wrap' \
         --bind 'ctrl-h:execute($SHELL -c "cmd=\$(echo {} | awk \"{print \\\$1}\"); \$cmd --help 2>&1 | less -R")'
  ) || sk_exit=$?

  # --print-query always outputs the final query on line 1.
  # Selected entry (if any) is on line 2+.
  local sk_query selection
  sk_query=$(printf '%s' "$sk_out" | head -1)
  selection=$(printf '%s' "$sk_out" | tail -n +2)

  if [[ -z "$selection" ]]; then
    # No match selected (0 results or Esc). If the query is "tool args", run it.
    # sk exits 130 on Esc/Ctrl-C — don't try to run anything in that case.
    [[ "$sk_exit" -eq 130 ]] && return 0
    if [[ "$sk_query" =~ ^([A-Za-z0-9_-]+)[[:space:]]+(.+)$ ]]; then
      local tool="${BASH_REMATCH[1]}" tool_args="${BASH_REMATCH[2]}"
      if jq -e --arg n "$tool" 'any(.[]; .name == $n and .installed == true)' "$INDEX" > /dev/null 2>&1; then
        # shellcheck disable=SC2086
        "$tool" $tool_args
        return 0
      fi
    fi
    return 0
  fi

  # Name is always the first whitespace-delimited token of the selected line
  local name
  name=$(printf '%s' "$selection" | awk '{print $1}')

  local entry installed type
  entry=$(jq -r --arg n "$name" '.[] | select(.name == $n)' "$INDEX")
  installed=$(printf '%s' "$entry" | jq -r '.installed')
  type=$(printf '%s' "$entry" | jq -r '.type')

  if [[ "$installed" == "true" ]]; then
    if [[ "$type" == "alias" || "$type" == "function" ]]; then
      local desc
      desc=$(printf '%s' "$entry" | jq -r '.description')
      echo "$name ($type): $desc"
      return 0
    fi
    # If the query was "name arg1 arg2 ...", pass those args through
    local args=""
    if [[ "$sk_query" =~ ^"$name"[[:space:]]+(.+)$ ]]; then
      args="${BASH_REMATCH[1]}"
    fi
    # shellcheck disable=SC2086
    "$name" $args
  else
    echo "Not installed. To install:"
    if [[ "$type" == "cask" ]]; then
      echo "  brew install --cask $name"
    else
      echo "  brew install $name"
    fi
  fi
}

cmd_recent() {
  local n="${1:-10}"
  _require jq

  if [[ ! -f "$INDEX" ]]; then
    echo "No index found. Run 'kit index' first." >&2
    exit 1
  fi

  _stale_warn

  jq -r --argjson n "$n" '
    sort_by(.dotfiles_added // "0000-00-00") | reverse | .[0:$n] |
    .[] |
    [
      .name,
      .type,
      ("added "    + (.dotfiles_added // "unknown")),
      (if .installed then
        (if .installed_at != null then "installed " + .installed_at else "installed" end)
       else "not yet installed" end)
    ] | @tsv
  ' "$INDEX" | column -t -s $'\t'
}

cmd_missing() {
  _require jq

  if [[ ! -f "$INDEX" ]]; then
    echo "No index found. Run 'kit index' first." >&2
    exit 1
  fi

  _stale_warn

  local missing
  missing=$(jq -r '
    .[] | select(.installed == false) |
    [.name, .type, ("added " + (.dotfiles_added // "unknown"))] | @tsv
  ' "$INDEX" | column -t -s $'\t')

  if [[ -z "$missing" ]]; then
    echo "All dotfiles tools are installed."
  else
    echo "$missing"
  fi
}

cmd_add() {
  local name="${1:-}"
  [[ -z "$name" ]] && { echo "Usage: kit add <formula>" >&2; exit 1; }
  echo "brew '$name'" >> "$DOTFILES/Brewfile"
  echo "Added brew '$name' to Brewfile" >&2
  brew install "$name"
  cmd_index
}

main "$@"
