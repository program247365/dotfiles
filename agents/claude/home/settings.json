{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "mcp__figma-desktop__get_design_context",
      "Bash(gh issue view:*)",
      "mcp__figma-desktop__get_metadata",
      "WebFetch(domain:linear.app)",
      "mcp__figma-desktop__get_screenshot",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "mcp__linear__list_issues",
      "mcp__linear__get_issue",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm tsc:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm test:*)",
      "Bash(docker logs:*)",
      "Bash(gh api:*)",
      "Bash(pnpm exec tsc:*)",
      "WebSearch",
      "Bash(git log:*)",
      "Bash(gh pr diff:*)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'TUI_REVIEW_BROADCAST=1 python3 /Users/kevin/code/tools/fast-code-reviewer/hooks/posttooluse.py'",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "greptile@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "agent-sdk-dev@claude-code-plugins": true,
    "code-review@claude-code-plugins": true,
    "commit-commands@claude-code-plugins": true,
    "explanatory-output-style@claude-code-plugins": true,
    "feature-dev@claude-code-plugins": true,
    "frontend-design@claude-code-plugins": true,
    "hookify@claude-code-plugins": false,
    "learning-output-style@claude-code-plugins": true,
    "plugin-dev@claude-code-plugins": true,
    "pr-review-toolkit@claude-code-plugins": true,
    "ralph-wiggum@claude-code-plugins": true,
    "security-guidance@claude-code-plugins": true
  }
}
