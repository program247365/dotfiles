{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "WebFetch(domain:www.lazyvim.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebSearch",
      "WebFetch(domain:bear.app)",
      "Read(//Users/kevin/.claude/**)",
      "WebFetch(domain:www.anthropic.com)",
      "Bash(python3:*)",
      "Skill(bear-notes)",
      "Skill(plan-exit-review)",
      "Skill(workday)",
      "Skill(visual-explainer)",
      "WebFetch(domain:docs.anthropic.com)",
      "mcp__plugin_playwright_playwright__browser_run_code",
      "Bash(qmd query:*)",
      "Bash(qmd search:*)",
      "Bash(bcli search:*)",
      "Bash(qmd collection:*)",
      "Bash(cat:*)",
      "Bash(qmd status:*)",
      "Bash(qmd:*)",
      "mcp__plugin_playwright_playwright__browser_close",
      "Bash(bcli ls:*)",
      "Bash(bcli tags:*)",
      "Read(//Users/kevin/.local/bin/**)",
      "Bash(bcli --help)",
      "Bash(~/.local/bin/bcli search:*)",
      "WebFetch(domain:randsinrepose.com)",
      "Skill(update-config)",
      "WebFetch(domain:docs.warp.dev)",
      "Bash(~/.local/bin/bcli get:*)",
      "WebFetch(domain:www.msgvault.io)",
      "mcp__msgvault__search_messages",
      "mcp__msgvault__get_stats",
      "mcp__msgvault__list_messages",
      "Bash(kit --help)",
      "Bash(git:*)",
      "Bash(bash /Users/kevin/.dotfiles/kit/test.sh 2>&1)",
      "Bash(kit index:*)",
      "Read(//Users/kevin/.kit/**)",
      "Bash(bash -c 'set -euo pipefail; PASS=0; FAIL=0; \\(\\(PASS++\\)\\); \\(\\(FAIL++\\)\\); echo \"pass=$PASS fail=$FAIL\"')",
      "Bash(bash -x /Users/kevin/.dotfiles/kit/test.sh)",
      "Bash(bash -c 'set -euo pipefail; PASS=0; echo \"before\"; \\(\\(PASS++\\)\\); echo \"after: $PASS\"')",
      "Bash(bash /Users/kevin/.dotfiles/kit/test.sh)",
      "Bash(jq:*)",
      "Bash(bash kit/test.sh)",
      "Bash(echo \"EXIT: $?\")",
      "Bash(echo \"exit: $?\")",
      "Bash(bash -n ~/.dotfiles/bin/dot)",
      "Bash(jq -r '.[] | select\\(.name == \"\"mise\"\" or .name == \"\"bat\"\" or .name == \"\"apfel\"\" or .name == \"\"cocogitto\"\"\\) | \"\"\\\\\\(.name\\): \\\\\"\"\\\\\\(.description\\)\\\\\"\"\"\"' ~/.kit/index.json)",
      "Bash(jq -r '.[] | select\\(.name == \"\"\"\"bat\"\"\"\"\\) | .description' ~/.kit/index.json)"
    ],
    "deny": [],
    "ask": []
  },
  "disabledMcpjsonServers": [
    "figma"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/agents/claude/hooks/guard-destructive.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude finished\" with title \"Claude Code\" sound name \"Ping\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  }
}
